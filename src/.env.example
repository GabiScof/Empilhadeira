# Copie para .env e ajuste. [ref: docs/hardware-deployment.md]

# --- Modo de operação ---
SIM=1                          # 1=simulação, 0=hardware real
MAP=corredor_pequeno           # mapa padrão (pi/maps/<nome>.json)

# --- Raspberry Pi: servidor WebSocket ---
PI_HOST=0.0.0.0
PI_PORT=8000

# IP do Pi visto pelo celular (frontend Vite)
VITE_PI_WS_URL=ws://192.168.0.10:8000/ws

# --- Serial Pi ↔ ESP32 (só SIM=0) ---
SERIAL_PORT=/dev/ttyUSB0
SERIAL_BAUDRATE=115200

# --- Câmera (só SIM=0) ---
CAMERA_INDEX=0
CAMERA_FRAME_WIDTH=1280
CAMERA_FRAME_HEIGHT=720
REQUIRE_CAMERA_CALIBRATION=1   # 0 = aceita intrínsecos placeholder (impreciso)

# --- Missão ---
MISSION_SEED=42
MISSION_RESUME_TRIGGER=button  # button | limit_switch (TODO equipe)
TAG_STANDOFF_M=0.15
