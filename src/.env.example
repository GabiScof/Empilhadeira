# Exemplo de configuracao de ambiente. Copie para .env e ajuste.
# [ref: Secao 3 e 5 da AGENTS.md]

# --- Raspberry Pi: servidor WebSocket (Frontend <-> Pi) ---
PI_HOST=0.0.0.0
PI_PORT=8000

# IP do Pi visto pelo celular (alvo do WebSocket no frontend).
# TODO(equipe): definir conforme o Access Point Wi-Fi (Pi ou roteador).
VITE_PI_WS_URL=ws://192.168.0.10:8000/ws

# --- Serial (Pi <-> ESP32) ---
SERIAL_PORT=/dev/ttyUSB0
SERIAL_BAUDRATE=115200
